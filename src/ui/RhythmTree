export type RhythmNodeType =
  | 'measure'
  | 'division'
  | 'note'

export type RhythmNode = {
  id: string

  type: RhythmNodeType

  startRatio: number
  endRatio: number

  ratio?: {
    actual: number
    normal: number
  }

  duration?: number

  children?: RhythmNode[]
}

export type RhythmTree = {
  measureCount: number
  root: RhythmNode
}

function createId(prefix: string, index: number): string {
  return `${prefix}-${index}`
}

export function createEmptyMeasureTree(): RhythmTree {
  return {
    measureCount: 1,

    root: {
      id: 'measure-1',
      type: 'measure',

      startRatio: 0,
      endRatio: 1,

      children: [],
    },
  }
}

export function createQuarterDivisionTree(): RhythmTree {
  const quarterSize = 1 / 4

  const children: RhythmNode[] = []

  for (let i = 0; i < 4; i += 1) {
    const start = i * quarterSize
    const end = start + quarterSize

    children.push({
      id: createId('quarter', i + 1),

      type: 'division',

      startRatio: start,
      endRatio: end,

      duration: 1,
    })
  }

  return {
    measureCount: 1,

    root: {
      id: 'measure-1',
      type: 'measure',

      startRatio: 0,
      endRatio: 1,

      children,
    },
  }
}

export function createTripletTree(): RhythmTree {
  const tripletSize = 1 / 3

  const children: RhythmNode[] = []

  for (let i = 0; i < 3; i += 1) {
    const start = i * tripletSize
    const end = start + tripletSize

    children.push({
      id: createId('triplet', i + 1),

      type: 'note',

      startRatio: start,
      endRatio: end,

      ratio: {
        actual: 3,
        normal: 2,
      },

      duration: 1 / 3,
    })
  }

  return {
    measureCount: 1,

    root: {
      id: 'measure-1',
      type: 'measure',

      startRatio: 0,
      endRatio: 1,

      children,
    },
  }
}

export function createNestedNineletTree(): RhythmTree {
  const outerTripletSize = 1 / 3

  const outerChildren: RhythmNode[] = []

  for (let outer = 0; outer < 3; outer += 1) {
    const outerStart = outer * outerTripletSize
    const outerEnd = outerStart + outerTripletSize

    const innerChildren: RhythmNode[] = []

    for (let inner = 0; inner < 3; inner += 1) {
      const innerSize = outerTripletSize / 3

      const innerStart = outerStart + inner * innerSize
      const innerEnd = innerStart + innerSize

      innerChildren.push({
        id: `ninelet-${outer + 1}-${inner + 1}`,

        type: 'note',

        startRatio: innerStart,
        endRatio: innerEnd,

        ratio: {
          actual: 3,
          normal: 2,
        },

        duration: 1 / 9,
      })
    }

    outerChildren.push({
      id: `outer-triplet-${outer + 1}`,

      type: 'division',

      startRatio: outerStart,
      endRatio: outerEnd,

      ratio: {
        actual: 3,
        normal: 2,
      },

      children: innerChildren,
    })
  }

  return {
    measureCount: 1,

    root: {
      id: 'measure-1',
      type: 'measure',

      startRatio: 0,
      endRatio: 1,

      children: outerChildren,
    },
  }
}
